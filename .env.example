# PiAssistant Environment Variables
# Copy to .env and fill in real values: cp .env.example .env

# Claude API (required)
ANTHROPIC_API_KEY=sk-ant-...

# OpenWeatherMap (required for weather)
# Get free key at: https://home.openweathermap.org/api_keys
OPENWEATHERMAP_API_KEY=

# NewsAPI (required for news)
# Get free key at: https://newsapi.org/register
NEWSAPI_KEY=
