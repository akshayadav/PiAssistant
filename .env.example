# PiAssistant Environment Variables
# Copy to .env and fill in real values: cp .env.example .env

# LLM backend: "anthropic" (Claude API) or "local" (LM Studio / Ollama)
LLM_BACKEND=local

# Claude API (required when LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Local LLM via LM Studio (used when LLM_BACKEND=local)
# LM Studio exposes OpenAI-compatible API on Mac Mini
LMSTUDIO_URL=http://10.0.0.131:1234
LMSTUDIO_MODEL=qwen3-8b
# Vision model for image analysis (must be multimodal, e.g. Gemma 3)
LMSTUDIO_VISION_MODEL=google/gemma-4-e2b

# NewsAPI (required for news)
# Get free key at: https://newsapi.org/register
NEWSAPI_KEY=

# Newsdata.io (used for India headlines)
# Get free key at: https://newsdata.io/register
NEWSDATA_API_KEY=

# Amazon Orders (optional — for order tracking widget)
# WARNING: These are stored in plaintext. Keep .env file secure.
AMAZON_EMAIL=
AMAZON_PASSWORD=
AMAZON_OTP_SECRET=

# Google Calendar (optional — for calendar widget)
# Download OAuth client JSON from Google Cloud Console
GOOGLE_CALENDAR_CREDENTIALS_JSON=
# Token is auto-generated after: python -m piassistant auth-google
GOOGLE_CALENDAR_TOKEN_PATH=data/google_token.json

# iCloud Calendar (optional — for calendar widget)
# Use an app-specific password from appleid.apple.com
ICLOUD_CALDAV_EMAIL=
ICLOUD_CALDAV_PASSWORD=

# Assistant display name (shown in dashboard title, chat labels)
ASSISTANT_NAME=Bunty

# API key for remote access (protects POST/DELETE endpoints)
# Leave empty for local-only mode (no auth required)
# Set this when accessing PiAssistant over Tailscale from outside LAN
API_KEY=

# Terminal (SSH bridge to Mac Mini — optional)
# Requires TERMINAL_PASSWORD to be set — terminal is disabled without it
TERMINAL_SSH_HOST=
TERMINAL_SSH_USER=
TERMINAL_SSH_KEY=
TERMINAL_SSH_PORT=22
TERMINAL_PASSWORD=

# Camera Feed (Jetson MJPEG proxy — optional)
# Requires FEED_PASSWORD to be set — feed is disabled without it
# JETSON_CAMERA_URL points at the Jetson running deploy/jetson-camera/
JETSON_CAMERA_URL=
FEED_PASSWORD=

# TTS — Text-to-Speech (Kokoro on Mac Mini + Piper on Pi)
# Kokoro-FastAPI URL on Mac Mini (leave empty to skip Kokoro)
TTS_KOKORO_URL=
TTS_KOKORO_VOICE=af_nova
# Piper TTS fallback (requires 'piper' binary + voice model on Pi)
TTS_PIPER_ENABLED=true
TTS_PIPER_MODEL=
TTS_SPEED=1.0

# Weather uses Open-Meteo (free, no key required)
